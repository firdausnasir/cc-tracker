# ─── Supabase Postgres ──────────────────────────────────────────────────────
# Supabase Dashboard → Project → Connect → ORMs (Prisma).
#
# DATABASE_URL = the POOLED connection (Transaction pooler, port 6543).
#   Used by the app at runtime on Vercel serverless. MUST include pgbouncer=true.
# DIRECT_URL   = the DIRECT connection (Session, port 5432).
#   Used only by `prisma migrate` / `prisma db push`. Not used at runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─── Auth.js (NextAuth v5) ──────────────────────────────────────────────────
# Generate with:  npx auth secret   (or:  openssl rand -base64 32 )
AUTH_SECRET="replace-me-with-a-32-byte-random-string"

# Set to your deployed origin on self-host. On Vercel this is auto-detected,
# so you can omit it there.
# AUTH_URL="https://your-app.vercel.app"
