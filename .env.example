# cc-tracker — environment. Copy to .env and fill in. .env is gitignored.
#
# All values are read from process.env at runtime (Node). docker-compose passes
# this file through `env_file:` and overrides DATABASE_URL to the mounted volume.

# --- Database (SQLite) ---------------------------------------------------------
# Local dev / Prisma CLI use this host path. Docker overrides it to the mounted
# volume (file:/data/cc.db) via docker-compose, which bind-mounts ./data → /data.
DATABASE_URL="file:./data/cc.db"

# --- Auth.js (NextAuth v5) -----------------------------------------------------
# Required. Generate one with: openssl rand -base64 32
AUTH_SECRET=""
# Optional. trustHost is enabled, so this is only needed if URL auto-detection is
# wrong behind a proxy. e.g. https://cards.example.com
# AUTH_URL=""

# --- AI statement import (OpenAI-compatible chat-completions endpoint) ---------
# Leave unset to disable PDF import; the feature fails loudly if only half-set.
OPENAI_BASE_URL=""
OPENAI_API_KEY=""
OPENAI_MODEL=""
